{
  "name": "codex-account-switcher",
  "version": "0.12.5",
  "private": true,
  "description": "Windows desktop account switcher for Codex file-based credentials",
  "author": "ciaooo55",
  "repository": {
    "type": "git",
    "url": "https://github.com/ciaooo55/codex-account-switcher.git"
  },
  "homepage": "https://github.com/ciaooo55/codex-account-switcher",
  "main": "./out/main/index.js",
  "type": "module",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "npm run build && playwright test",
    "package:win": "npm run build && electron-builder --win nsis portable --publish never",
    "verify": "npm run typecheck && npm run test && npm run build"
  },
  "dependencies": {
    "@tanstack/react-virtual": "3.14.6",
    "acorn": "^8.15.0",
    "electron-updater": "^6.8.9",
    "fflate": "^0.8.3",
    "lucide-react": "^0.468.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.52.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^22.15.0",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@vitejs/plugin-react": "^4.4.1",
    "electron": "^43.1.1",
    "electron-builder": "^26.0.12",
    "electron-vite": "^3.1.0",
    "jsdom": "^26.1.0",
    "typescript": "^5.8.3",
    "vite": "^6.3.5",
    "vitest": "^3.1.3"
  },
  "build": {
    "appId": "com.local.codex-account-switcher",
    "productName": "Codex Account Switcher",
    "asar": true,
    "files": [
      "out/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "build/icon.png",
        "to": "icon.png"
      }
    ],
    "directories": {
      "output": "release"
    },
    "win": {
      "icon": "build/icon.ico",
      "target": [
        "nsis",
        "portable"
      ]
    },
    "publish": [
      {
        "provider": "github",
        "owner": "ciaooo55",
        "repo": "codex-account-switcher"
      }
    ],
    "nsis": {
      "artifactName": "Codex-Account-Switcher-Setup-${version}.${ext}",
      "include": "build/installer.nsh",
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "portable": {
      "artifactName": "Codex-Account-Switcher-Portable-${version}.${ext}"
    }
  }
}
